# 이 파일을 복사해서 .env 로 저장한 후 값을 채우세요
# cp .env.example .env

# Flask 세션 서명 키 (32자 이상 랜덤 문자열)
# 생성: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=여기에_랜덤_키를_입력하세요

# PostgreSQL 연결 URL
DATABASE_URL=postgresql://유저명:비밀번호@localhost:5432/smartsolution

# 최초 admin 계정 비밀번호 (DB 초기화 시 한 번만 사용)
ADMIN_PASSWORD=여기에_관리자_비밀번호를_입력하세요
